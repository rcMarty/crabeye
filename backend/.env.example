DATABASE_URL=postgres://crabeye_user:S3cret@localhost:5431/crabeye_db
GITHUB_TOKEN=yourTokenHere

REPO_OWNER=rust-lang
REPO_NAME=rust

LOG_LEVEL=info

# ── Server ───────────────────────────────────────
# SERVER_HOST=0.0.0.0
# SERVER_PORT=7878

# ── Sync / monitoring ────────────────────────────
# CHECK_INTERVAL_SECS=120        # how often (seconds) the state monitor re-syncs in serve mode
# LOOKBACK_PERIOD_DAYS=30        # how many days back to look on first run (no previous event in db)

# ── Database ─────────────────────────────────────
# BULK_CHUNK_SIZE=10000          # max rows per batch INSERT
