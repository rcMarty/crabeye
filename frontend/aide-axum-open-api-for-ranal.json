  "components": {
    "schemas": {
      "Contributor": {
        "type": "object",
        "properties": {
          "github_id": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "github_name": {
            "type": "string"
          },
          "name": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "github_id",
          "github_name"
        ]
      },
      "FileNode": {
        "type": "object",
        "properties": {
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FileNode"
            }
          },
          "modifications": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "modifications",
          "children"
        ]
      },
      "FilesModifiedByTeamParams": {
        "description": "Parameters for getting files modified by a team",
        "type": "object",
        "properties": {
          "from_timestamp": {
            "description": "Optional start date (ISO 8601). default Now, example = \"2025-01-01\"",
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "group_level": {
            "description": "Group results by folder level\n\n - \"none\": Return a flat list of files with modification counts (default)\n - Number (e.g., 1, 2): Group by folder hierarchy up to that depth level\n - \"all\": Group by the full folder hierarchy\n\n Examples:\n - 1: Groups into top-level folders (src/, library/, etc.)\n - 2: Groups into subfolders (src/doc/, library/core/, etc.)",
            "allOf": [
              {
                "$ref": "#/components/schemas/GroupingLevel"
              }
            ]
          },
          "last_n_days": {
            "description": "Number of days to look back, default 7, example = 30",
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "repository": {
            "description": "Repository identifier to filter, example = \"owner/repo\"",
            "type": "string"
          },
          "team_name": {
            "description": "Team name to filter contributors",
            "type": "string"
          }
        },
        "required": [
          "repository",
          "team_name"
        ]
      },
      "FilesModifiedResponse": {
        "anyOf": [
          {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "$ref": "#/components/schemas/FileNode"
          }
        ]
      },
      "GroupingLevel": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "integer",
            "format": "int64"
          },
          {
            "type": "null"
          }
        ]
      },
      "IssueEvent": {
        "type": "object",
        "properties": {
          "event": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "partial-date-time"
          }
        },
        "required": [
          "event",
          "timestamp"
        ]
      },
      "IssueLabel": {
        "type": "object",
        "properties": {
          "action": {
            "$ref": "#/components/schemas/LabelEventAction"
          },
          "label": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "partial-date-time"
          }
        },
        "required": [
          "label",
          "timestamp",
          "action"
        ]
      },
      "IssueStateParams": {
        "description": "Parameters for getting PR state at a specific timestamp",
        "type": "object",
        "properties": {
          "issue": {
            "description": "Pull request number",
            "type": "integer",
            "format": "int64"
          },
          "repository": {
            "description": "Repository identifier to filter reviews, example = \"owner/repo\"",
            "type": "string"
          },
          "timestamp": {
            "description": "Timestamp to get the PR state at, format: YYYY-MM-DD",
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "repository",
          "issue",
          "timestamp"
        ]
      },
      "LabelEventAction": {
        "type": "string",
        "enum": [
          "ADDED",
          "REMOVED"
        ]
      },
      "PaginatedResponse_for_Contributor": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contributor"
            }
          },
          "page": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "per_page": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "total_count": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "required": [
          "items",
          "total_count",
          "page",
          "per_page"
        ]
      },
      "PaginatedResponse_for_PrEvent": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PrEvent"
            }
          },
          "page": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "per_page": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          },
          "total_count": {
            "type": "integer",
            "format": "uint",
            "minimum": 0
          }
        },
        "required": [
          "items",
          "total_count",
          "page",
          "per_page"
        ]
      },
      "Pagination": {
        "description": "Common pagination parameters\n Used in multiple endpoints\n Defaults to page 1 and 100 items per page\n If page or per_page is not provided, defaults are used",
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int64"
          },
          "per_page": {
            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "page",
          "per_page"
        ]
      },
      "PrCountParams": {
        "description": "Parameters for getting PR count by status",
        "type": "object",
        "properties": {
          "repository": {
            "description": "Repository identifier to filter PRs, example = \"owner/repo\"",
            "type": "string"
          },
          "state": {
            "description": "Status of the pull requests to filter by",
            "allOf": [
              {
                "$ref": "#/components/schemas/PullRequestStatusRequest"
              }
            ]
