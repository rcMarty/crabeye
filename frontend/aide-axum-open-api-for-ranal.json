    "/api/pr/files-modified-by-team": {
      "get": {
        "tags": [
          "PR"
        ],
        "description": "Get files modified by a team within a time window, ordered by modification count descending. The group_level parameter controls grouping: 'none' returns a flat list, a number groups by that folder depth level, 'all' groups by the full folder hierarchy.",
        "parameters": [
          {
            "in": "query",
            "name": "from_timestamp",
            "description": "Optional start date (ISO 8601). default Now, example = \"2025-01-01\"",
            "schema": {
              "description": "Optional start date (ISO 8601). default Now, example = \"2025-01-01\"",
              "type": [
                "string",
                "null"
              ],
              "format": "date"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "group_level",
            "description": "Group results by folder level\n\n - \"none\": Return a flat list of files with modification counts (default)\n - Number (e.g., 1, 2): Group by folder hierarchy up to that depth level\n - \"all\": Group by the full folder hierarchy\n\n Examples:\n - 1: Groups into top-level folders (src/, library/, etc.)\n - 2: Groups into subfolders (src/doc/, library/core/, etc.)",
            "schema": {
              "description": "Group results by folder level\n\n - \"none\": Return a flat list of files with modification counts (default)\n - Number (e.g., 1, 2): Group by folder hierarchy up to that depth level\n - \"all\": Group by the full folder hierarchy\n\n Examples:\n - 1: Groups into top-level folders (src/, library/, etc.)\n - 2: Groups into subfolders (src/doc/, library/core/, etc.)",
              "$ref": "#/components/schemas/GroupingLevel"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "last_n_days",
            "description": "Number of days to look back, default 7, example = 30",
            "schema": {
              "description": "Number of days to look back, default 7, example = 30",
              "type": [
                "integer",
                "null"
              ],
              "format": "int64"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "repository",
            "description": "Repository identifier to filter, example = \"owner/repo\"",
            "required": true,
            "schema": {
              "description": "Repository identifier to filter, example = \"owner/repo\"",
              "type": "string"
            },
            "style": "form"
          },
          {
            "in": "query",
            "name": "team_name",
            "description": "Team name to filter contributors",
            "required": true,
            "schema": {
              "description": "Team name to filter contributors",
              "type": "string"
            },
            "style": "form"
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FilesModifiedResponse"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
